{
	"model": "Claude Sonnet (OpenAI compat)",
	"request_model": "claude-sonnet-4-6",
	"url": "{{BASE_URL}}/v1/chat/completions",
	"method": "POST",
	"headers": {
		"Authorization": "Bearer {{API_KEY}}",
		"Content-Type": "application/json"
	},
	"body": {
		"model": "{{MODEL}}",
		"max_tokens": 20,
		"stream": false,
		"messages": [
			{
				"role": "user",
				"content": "{{PROMPT}}"
			}
		]
	},
	"response": {
		"success_contains": "{{EXPECTED_ANSWER}}"
	},
	"probe": {
		"slow_latency": "5s",
		"timeout": "10s",
		"retry": 0
	}
}
